datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                   String    @id @default(cuid())
  username             String    @unique
  email                String    @unique
  password             String?
  googleId             String?   @unique
  displayName          String?
  profileImage         String?   @default("https://via.placeholder.com/150")
  coverImage           String?   @default("https://images.unsplash.com/photo-1579546929518-9e396f3cc809")
  profileType          String    @default("CREATIVE") // CREATIVE, SCOUT
  bio                  String?   @default("Creative explorer on Micollab.")
  longAbout            String?
  isVerified           String?   @default("NO") // NO, PENDING, YES
  isEmailVerified      Boolean   @default(false)
  verificationOTP      String?
  otpExpiresAt         DateTime?
  resetPasswordToken   String?
  resetPasswordExpires DateTime?
  location             String?   @default("Lagos, Nigeria")
  skills               String? // comma-separated
  availabilityStatus   String?   @default("AVAILABLE") // AVAILABLE, BUSY, OPEN_TO_COLLAB
  website              String?

  // Reputation Metrics
  reputationScore Int @default(0)
  completionRate  Int @default(100)
  responseRate    Int @default(100)

  // Admin & Moderation
  isAdmin         Boolean @default(false)
  isSuperAdmin    Boolean @default(false)
  isBanned        Boolean @default(false)

  // Usage Metrics
  lastActive      DateTime @default(now())
  totalTimeSpent  Int      @default(0) // Time spent in seconds

  socialLinks String? // Stored as JSON string in SQLite

  // Preferences
  emailNotifications  Boolean @default(true)
  pushNotifications   Boolean @default(true)
  profileVisibility   String  @default("PUBLIC") // PUBLIC, PRIVATE, NETWORK_ONLY

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  posts             Post[]
  collabs           Collab[]
  proposals         Proposal[]
  connections       Connection[]        @relation("UserConnections")
  connectedTo       Connection[]        @relation("ConnectedTo")
  sentRequests      ConnectionRequest[] @relation("SentRequests")
  receivedRequests  ConnectionRequest[] @relation("ReceivedRequests")
  circleMemberships CircleMember[]
  notifications     Notification[]      @relation("UserNotifications")
  triggeredAlerts   Notification[]      @relation("TriggeredBy")

  portfolioItems    PortfolioItem[]
  testimonials      Testimonial[]     @relation("ReceivedTestimonials")
  givenTestimonials Testimonial[]     @relation("GivenTestimonials")
  openedDisputes    Dispute[]         @relation("OpenedDisputes")
  disputeMessages   DisputeMessage[]
  analytics         UserAnalytics?
  profileAnalytics  ProfileAnalytics[]
  credits           PortfolioCredit[] @relation("UserCredits")
  comments          Comment[]
  postLikes         PostLike[]

  // New Circle Relations
  ownedCircles            Circle[]                  @relation("CircleOwner")
  circleTasks             CircleTask[]              @relation("AssignedTasks")
  reportedTasks           CircleTask[]              @relation("ReportedTasks")
  circleMessages          CircleMessage[]
  projectCredits          ProjectCredit[]
  taskComments            TaskComment[]
  ConversationParticipant ConversationParticipant[]

  // Trust & Safety Relations
  blockedUsers   Block[]  @relation("Blocker")
  blockedBy      Block[]  @relation("Blocked")
  reportsMade    Report[] @relation("Reporter")
  reportsReceived Report[] @relation("Reported")

  // Wallet & Payments
  wallet             Wallet?
  transactions       Transaction[]
  withdrawalRequests WithdrawalRequest[]
  sentDirectMessages Message[] @relation("SentDirectMessages")
}

model PortfolioItem {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String?
  category    String // Video, Photography, Music, Writing, etc.
  projectType String?   @default("PERSONAL") // CLIENT, PERSONAL, COMMERCIAL
  date        DateTime?
  featured    Boolean   @default(false)
  viewCount   Int       @default(0)

  media   PortfolioMedia[]
  tags    PortfolioTag[]
  credits PortfolioCredit[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PortfolioMedia {
  id              String        @id @default(cuid())
  portfolioItemId String
  portfolioItem   PortfolioItem @relation(fields: [portfolioItemId], references: [id])
  url             String
  type            String        @default("IMAGE") // IMAGE, VIDEO, AUDIO
  order           Int           @default(0)
}

model PortfolioTag {
  id              String        @id @default(cuid())
  portfolioItemId String
  portfolioItem   PortfolioItem @relation(fields: [portfolioItemId], references: [id])
  name            String
}

model PortfolioCredit {
  id              String        @id @default(cuid())
  portfolioItemId String
  portfolioItem   PortfolioItem @relation(fields: [portfolioItemId], references: [id])
  creditedUserId  String
  user            User          @relation("UserCredits", fields: [creditedUserId], references: [id], onDelete: Cascade)
  role            String // Director, Producer, Editor, etc.
}

model Testimonial {
  id         String   @id @default(cuid())
  fromUserId String
  fromUser   User     @relation("GivenTestimonials", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUserId   String
  toUser     User     @relation("ReceivedTestimonials", fields: [toUserId], references: [id], onDelete: Cascade)
  content    String
  rating     Int      @default(5)
  createdAt  DateTime @default(now())
}

model UserAnalytics {
  id                String @id @default(cuid())
  userId            String @unique
  user              User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  profileViews      Int    @default(0)
  portfolioViews    Int    @default(0)
  searchAppearances Int    @default(0)
}

model ProfileAnalytics {
  id            String   @id @default(cuid())
  userId        String
  date          DateTime @db.Date
  views         Int      @default(0)
  searchAppears Int      @default(0)
  
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model Post {
  id             String    @id @default(uuid())
  content        String?   @db.Text
  contentType    String    @default("TEXT") // TEXT, IMAGE, VIDEO
  mediaUrl       String?
  caption        String?   @db.Text
  postCategory   String    @default("GENERAL") // UPDATE, SHOWCASE, QUESTION
  tags           String?   // Added tags field for specializations mapping
  isCollabCard   Boolean   @default(false)
  collabId       String?

  createdAt DateTime @default(now())
  creator   User     @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  creatorId String

  // Repost logic
  originalPostId String?
  originalPost   Post?   @relation("Reposts", fields: [originalPostId], references: [id])
  reposts        Post[]  @relation("Reposts")

  // Social interactions
  likes         Int @default(0)
  commentsCount Int @default(0)

  postComments Comment[]
  postLikes    PostLike[]

  isEdited   Boolean @default(false)
  isArchived Boolean @default(false)
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())

  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String
}

model PostLike {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  @@unique([postId, userId])
}

model Collab {
  id              String    @id @default(cuid())
  title           String
  description     String
  budget          String?
  category        String
  location        String
  projectType     String    @default("ONE_OFF") // ONE_OFF, LONG_TERM
  deadline        DateTime?
  experienceLevel String?   @default("ALL")
  duration        String?
  status          String    @default("OPEN") // OPEN, CLOSED, COMPLETED
  crossPostToFeed Boolean   @default(false)
  isVerified      Boolean   @default(false)

  poster    User     @relation(fields: [posterId], references: [id], onDelete: Cascade)
  posterId  String
  targetCircleId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  requirements Requirement[]
  attachments  Attachment[]
  proposals    Proposal[]
}

model Requirement {
  id       String @id @default(cuid())
  skill    String
  collab   Collab @relation(fields: [collabId], references: [id])
  collabId String
}

model Attachment {
  id         String    @id @default(cuid())
  url        String
  name       String
  collabId   String?
  collab     Collab?   @relation(fields: [collabId], references: [id])
  proposalId String?
  proposal   Proposal? @relation(fields: [proposalId], references: [id])
}

model Proposal {
  id             String  @id @default(cuid())
  coverLetter    String
  bidAmount      String?
  status         String  @default("PENDING") // PENDING, ACCEPTED, REJECTED
  escrowStatus   String  @default("NONE") // NONE, HELD, RELEASED, REFUNDED, DISPUTED
  portfolioLinks String? // JSON string

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  collab      Collab       @relation(fields: [collabId], references: [id])
  collabId    String
  attachments Attachment[]
  dispute     Dispute?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Connection {
  id          String   @id @default(cuid())
  userId      String
  connectedId String
  status      String   @default("ACCEPTED")
  createdAt   DateTime @default(now())

  user        User @relation("UserConnections", fields: [userId], references: [id], onDelete: Cascade)
  connectedTo User @relation("ConnectedTo", fields: [connectedId], references: [id], onDelete: Cascade)

  @@unique([userId, connectedId])
}

model ConnectionRequest {
  id         String   @id @default(cuid())
  fromUserId String
  toUserId   String
  status     String   @default("PENDING") // PENDING, ACCEPTED, REJECTED
  createdAt  DateTime @default(now())

  fromUser User @relation("SentRequests", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User @relation("ReceivedRequests", fields: [toUserId], references: [id], onDelete: Cascade)
}

model Circle {
  id               String  @id @default(cuid())
  ownerId          String
  owner            User    @relation("CircleOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  title            String
  slug             String  @unique
  description      String?
  category         String
  coverImage       String?
  visibility       String  @default("PRIVATE") // PUBLIC, PRIVATE, HIDDEN
  compensationType String  @default("NONE") // PAID, REVENUE_SHARE, NONE
  status           String  @default("ACTIVE") // ACTIVE, COMPLETED, ARCHIVED
  collabId         String? @unique

  members     CircleMember[]
  roles       CircleRole[]
  tasks       CircleTask[]
  messages    CircleMessage[]
  files       CircleFile[]
  folders     CircleFolder[]
  milestones  CircleMilestone[]
  credits     ProjectCredit[]
  invitations CircleInvitation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CircleMember {
  id       String   @id @default(cuid())
  circleId String
  circle   Circle   @relation(fields: [circleId], references: [id], onDelete: Cascade)
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role     String   @default("CONTRIBUTOR") // OWNER, ADMIN, CONTRIBUTOR, REVIEWER
  joinedAt DateTime @default(now())

  @@unique([circleId, userId])
}

model CircleRole {
  id          String  @id @default(cuid())
  circleId    String
  circle      Circle  @relation(fields: [circleId], references: [id], onDelete: Cascade)
  title       String
  description String?
  isOpen      Boolean @default(true)
  assignedTo  String? // userId
}

model CircleTask {
  id          String    @id @default(cuid())
  circleId    String
  circle      Circle    @relation(fields: [circleId], references: [id], onDelete: Cascade)
  title       String
  description String?
  status      String    @default("TODO") // TODO, IN_PROGRESS, REVIEW, APPROVED, COMPLETED
  priority    String    @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  deadline    DateTime?
  assignedTo  String? // userId
  assignee    User?     @relation("AssignedTasks", fields: [assignedTo], references: [id], onDelete: Cascade)
  createdBy   String
  reporter    User      @relation("ReportedTasks", fields: [createdBy], references: [id], onDelete: Cascade)

  taskCode         String?
  estimatedEffort  Int?
  labels           String? // comma-separated tags
  rejectionComment String?
  activityLog      String? // JSON stringified history log
  dependencies     String? // JSON array of task IDs
  linkedTasks      String? // JSON array of task IDs

  parentId String?
  parent   CircleTask?  @relation("TaskSubtasks", fields: [parentId], references: [id], onDelete: Cascade)
  subtasks CircleTask[] @relation("TaskSubtasks")

  comments    TaskComment[]
  attachments TaskAttachment[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model TaskComment {
  id        String     @id @default(cuid())
  taskId    String
  task      CircleTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String
  user      User       @relation(fields: [userId], references: [id])
  content   String
  createdAt DateTime   @default(now())
}

model TaskAttachment {
  id        String     @id @default(cuid())
  taskId    String
  task      CircleTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  fileUrl   String
  type      String
  createdAt DateTime   @default(now())
}

model CircleMessage {
  id        String  @id @default(cuid())
  circleId  String
  circle    Circle  @relation(fields: [circleId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User    @relation(fields: [senderId], references: [id], onDelete: Cascade)
  content   String
  type      String  @default("TEXT") // TEXT, MEDIA, SYSTEM
  replyToId String?

  reactions MessageReaction[]
  createdAt DateTime          @default(now())
}

model MessageReaction {
  id        String        @id @default(cuid())
  messageId String
  message   CircleMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  emoji     String
}

model CircleFile {
  id             String        @id @default(cuid())
  circleId       String
  circle         Circle        @relation(fields: [circleId], references: [id], onDelete: Cascade)
  uploadedBy     String
  fileUrl        String
  type           String
  version        Int           @default(1)
  folderId       String?
  folder         CircleFolder? @relation(fields: [folderId], references: [id], onDelete: Cascade)
  originalName   String?
  size           Int?
  sourceTaskId   String?
  versionHistory String? // JSON string
  accessList     String? // JSON string
  publicLinks    String? // JSON string
  activityLog    String? // JSON string
  comments       String? // JSON string
  isDeleted      Boolean       @default(false)
  deletedAt      DateTime?
  createdAt      DateTime      @default(now())
}

model CircleFolder {
  id           String         @id @default(cuid())
  circleId     String
  circle       Circle         @relation(fields: [circleId], references: [id], onDelete: Cascade)
  name         String
  parentId     String?
  parent       CircleFolder?  @relation("FolderSubfolders", fields: [parentId], references: [id], onDelete: Cascade)
  subfolders   CircleFolder[] @relation("FolderSubfolders")
  color        String?        @default("#3b82f6")
  icon         String?        @default("folder")
  files        CircleFile[]
  folderAccess String? // JSON String for folder-level access list

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CircleMilestone {
  id           String    @id @default(cuid())
  circleId     String
  circle       Circle    @relation(fields: [circleId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  deadline     DateTime?
  status       String    @default("PENDING") // PENDING, COMPLETED
  
  // Escrow & Payout Integration
  payoutAmount Float?
  payoutStatus String    @default("UNFUNDED") // UNFUNDED, FUNDED, RELEASED, DISPUTED
}

model ProjectCredit {
  id         String @id @default(cuid())
  circleId   String
  circle     Circle @relation(fields: [circleId], references: [id], onDelete: Cascade)
  userId     String
  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  creditRole String
}

model CircleInvitation {
  id        String   @id @default(cuid())
  circleId  String
  circle    Circle   @relation(fields: [circleId], references: [id], onDelete: Cascade)
  inviterId String
  inviteeId String
  status    String   @default("PENDING") // PENDING, ACCEPTED, REJECTED
  createdAt DateTime @default(now())
}

model Conversation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants ConversationParticipant[]
  messages     Message[]
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  conversationId String
  userId         String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
}

model Message {
  id             String        @id @default(cuid())
  content        String?
  mediaUrl       String?
  mediaType      String? // 'image', 'video', 'voice', etc.
  senderId       String
  sender         User          @relation("SentDirectMessages", fields: [senderId], references: [id], onDelete: Cascade)
  conversationId String
  createdAt      DateTime      @default(now())
  conversation   Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  isRead         Boolean       @default(false)
  isDelivered    Boolean       @default(false)
  readAt         DateTime?
  replyToId      String?
  replyTo        Message?      @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies        Message[]     @relation("MessageReplies")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String // CONNECTION_REQUEST, PROPOSAL_RECEIVED, COLLAB_ACCEPTED, MESSAGE_RECEIVED
  content   String
  relatedId String? // ID of the related object (collab, user, etc.)
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user          User    @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  triggeredBy   User?   @relation("TriggeredBy", fields: [triggeredById], references: [id], onDelete: Cascade)
  triggeredById String?
}

model Block {
  id        String   @id @default(cuid())
  blockerId String
  blocker   User     @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blockedId String
  blocked   User     @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([blockerId, blockedId])
}

model Report {
  id         String   @id @default(cuid())
  reporterId String
  reporter   User     @relation("Reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reportedId String
  reported   User     @relation("Reported", fields: [reportedId], references: [id], onDelete: Cascade)
  reason     String
  status     String   @default("PENDING") // PENDING, REVIEWED, RESOLVED
  createdAt  DateTime @default(now())
}

model Wallet {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  availableBalance Float    @default(0.0)
  escrowBalance    Float    @default(0.0)
  currency         String   @default("NGN")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Transaction {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount          Float
  feeAmount       Float?   @default(0) // Platform fee deducted
  netAmount       Float?   // Amount after fee
  currency        String   @default("NGN")
  type            String   // DEPOSIT, WITHDRAWAL, ESCROW_HOLD, ESCROW_RELEASE, PLATFORM_FEE
  status          String   @default("COMPLETED") // PENDING, COMPLETED, FAILED
  reference       String?  @unique // Paystack or external reference
  description     String?
  relatedEntityId String?  // e.g. Proposal ID, Milestone ID
  createdAt       DateTime @default(now())
}

model WithdrawalRequest {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount        Float
  currency      String   @default("NGN")
  payoutMethod  String   // BANK_ACCOUNT, PAYPAL
  payoutDetails String   // JSON string containing bank details or email
  status        String   @default("PENDING") // PENDING, PROCESSED, REJECTED
  adminNotes    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Dispute {
  id           String   @id @default(cuid())
  proposalId   String   @unique
  proposal     Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  openedById   String
  openedBy     User     @relation("OpenedDisputes", fields: [openedById], references: [id])
  reason       String
  status       String   @default("OPEN") // OPEN, RESOLVED_POSTER, RESOLVED_CREATIVE
  adminNotes   String?
  messages     DisputeMessage[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model DisputeMessage {
  id           String   @id @default(cuid())
  disputeId    String
  dispute      Dispute  @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  senderId     String
  sender       User     @relation(fields: [senderId], references: [id])
  message      String
  isAdmin      Boolean  @default(false)
  createdAt    DateTime @default(now())
}
